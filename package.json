{
  "name": "cadence",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Cadence — your backlog, in flow. Local task-management + autonomous-execution platform wrapping Claude Code.",
  "workspaces": ["shared", "server", "web"],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "dev": "bun run --filter='@cadence/server' --filter='@cadence/web' dev",
    "build": "bun run --filter='@cadence/shared' --filter='@cadence/server' --filter='@cadence/web' build",
    "typecheck": "bun run --filter='@cadence/*' typecheck",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun server/src/db/migrate.ts",
    "sidecar:build": "bun scripts/build-sidecar.ts",
    "sidecar:smoke": "bun scripts/sidecar-smoke.ts",
    "app:smoke": "bun scripts/app-smoke.ts",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.2"
  }
}
