# Dependencies
node_modules/

# Build output
dist/
build/
out/

# Local app data / SQLite (Cadence stores data under ~/.cadence, but ignore any local copies)
*.db
*.sqlite
*.sqlite3

# Env & secrets — NEVER commit
.env
.env.*
!.env.example
*.key
*.pem
*.p12
id_rsa*
*.secret
secrets/
*.local.json

# App/runtime data must never enter the repo (it lives in ~/.cadence)
/.cadence/
.cadence/

# Logs
*.log
logs/

# Local tooling / runtime state (Claude Code session locks, etc.)
.claude/

# OS / editor cruft
.DS_Store
.vscode/
.idea/
*.swp
