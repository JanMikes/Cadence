# Cadence local config — copy to `.env` (gitignored) and adjust as needed.
# Bun and Vite both load `.env`, so these apply to the gateway and the web dev
# server consistently. Ports are configurable so Cadence can avoid colliding
# with other local dev servers running at the same time.

# Gateway (HTTP+WS) port. The Vite dev proxy forwards /api here, so changing this
# one value keeps the server and the web proxy in sync.
CADENCE_PORT=4477

# Web (Vite) dev-server port. If taken, Vite picks the next free port.
CADENCE_WEB_PORT=5173
